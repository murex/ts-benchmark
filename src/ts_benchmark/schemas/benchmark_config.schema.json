{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Time-series benchmark config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "benchmark", "run"],
  "properties": {
    "version": {"type": "string"},
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "dataset", "protocol", "models"],
      "properties": {
        "description": {"type": ["string", "null"], "default": null},
        "name": {"type": "string", "minLength": 1},
        "dataset": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider"],
          "properties": {
            "name": {"type": ["string", "null"], "default": null},
            "description": {"type": ["string", "null"], "default": null},
            "provider": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": {"type": "string", "minLength": 1},
                "config": {"type": "object", "default": {}}
              }
            },
            "schema": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "layout": {"type": "string", "default": "wide"},
                "time_column": {"type": ["string", "null"], "default": null},
                "series_id_columns": {
                  "type": "array",
                  "default": [],
                  "items": {"type": "string"}
                },
                "target_columns": {
                  "type": "array",
                  "default": [],
                  "items": {"type": "string"}
                },
                "feature_columns": {
                  "type": "array",
                  "default": [],
                  "items": {"type": "string"}
                },
                "static_feature_columns": {
                  "type": "array",
                  "default": [],
                  "items": {"type": "string"}
                },
                "frequency": {"type": ["string", "null"], "default": "B"}
              }
            },
            "semantics": {"type": "object", "default": {}},
            "metadata": {"type": "object", "default": {}}
          }
        },
        "protocol": {
          "type": "object",
          "additionalProperties": false,
          "required": ["train_size", "test_size", "context_length", "horizon"],
          "properties": {
            "train_size": {"type": "integer", "minimum": 2},
            "test_size": {"type": "integer", "minimum": 1},
            "context_length": {"type": "integer", "minimum": 0},
            "horizon": {"type": "integer", "minimum": 1},
            "generation_mode": {
              "type": "string",
              "enum": ["forecast", "unconditional"],
              "default": "forecast"
            },
            "eval_stride": {"type": "integer", "minimum": 1, "default": 10},
            "train_stride": {"type": "integer", "minimum": 1, "default": 1},
            "n_model_scenarios": {"type": "integer", "minimum": 1, "default": 64},
            "n_reference_scenarios": {"type": "integer", "minimum": 1, "default": 128}
          }
        },
        "metrics": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "description": {"type": ["string", "null"], "default": null},
              "category": {"type": ["string", "null"], "default": null},
              "direction": {
                "type": ["string", "null"],
                "enum": ["minimize", "maximize", "target", null],
                "default": null
              },
              "target_value": {"type": ["number", "null"], "default": null},
              "params": {
                "type": "object",
                "default": {},
                "additionalProperties": true
              },
              "requirements": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "requires_realized_path": {"type": "boolean", "default": false},
                  "requires_reference_scenarios": {"type": "boolean", "default": false},
                  "multivariate_only": {"type": "boolean", "default": false},
                  "synthetic_only": {"type": "boolean", "default": false}
                }
              },
              "granularity": {"type": ["string", "null"], "default": null},
              "aggregation": {"type": ["string", "null"], "default": null}
            }
          }
        },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reference"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "description": {"type": ["string", "null"], "default": null},
              "reference": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "value"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["builtin", "plugin", "entrypoint"]
                  },
                  "value": {"type": "string", "minLength": 1}
                }
              },
              "params": {"type": "object", "default": {}},
              "pipeline": {
                "type": "object",
                "additionalProperties": false,
                "default": {"name": "raw", "steps": []},
                "required": ["name", "steps"],
                "properties": {
                  "name": {"type": "string", "minLength": 1},
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["type"],
                      "properties": {
                        "type": {"type": "string", "minLength": 1},
                        "params": {"type": "object", "default": {}}
                      }
                    }
                  }
                }
              },
              "metadata": {"type": "object", "default": {}},
              "execution": {
                "type": ["object", "null"],
                "default": null,
                "additionalProperties": false,
                "properties": {
                  "mode": {"type": "string", "enum": ["inprocess", "subprocess"], "default": "inprocess"},
                  "venv": {"type": ["string", "null"], "default": null},
                  "python": {"type": ["string", "null"], "default": null},
                  "cwd": {"type": ["string", "null"], "default": null},
                  "pythonpath": {
                    "type": "array",
                    "default": [],
                    "items": {"type": "string"}
                  },
                  "env": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution", "output"],
      "properties": {
        "name": {"type": ["string", "null"], "default": null},
        "description": {"type": ["string", "null"], "default": null},
        "seed": {"type": "integer", "default": 7},
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheduler"],
          "properties": {
            "device": {"type": ["string", "null"], "default": null},
            "scheduler": {
              "type": "string",
              "enum": ["auto", "sequential", "model_parallel"],
              "default": "auto"
            },
            "model_execution": {
              "type": ["object", "null"],
              "default": {"mode": "inprocess"},
              "additionalProperties": false,
              "properties": {
                "mode": {"type": "string", "enum": ["inprocess", "subprocess"], "default": "inprocess"},
                "venv": {"type": ["string", "null"], "default": null},
                "python": {"type": ["string", "null"], "default": null},
                "cwd": {"type": ["string", "null"], "default": null},
                "pythonpath": {
                  "type": "array",
                  "default": [],
                  "items": {"type": "string"}
                },
                "env": {
                  "type": "object",
                  "default": {},
                  "additionalProperties": {"type": "string"}
                }
              }
            }
          }
        },
        "tracking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mlflow": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {"type": "boolean", "default": false},
                "tracking_uri": {"type": ["string", "null"], "default": null},
                "experiment_name": {"type": "string", "default": "ts-benchmark"},
                "run_name": {"type": ["string", "null"], "default": null},
                "tags": {
                  "type": "object",
                  "default": {},
                  "additionalProperties": {"type": "string"}
                },
                "log_artifacts": {"type": "boolean", "default": true},
                "log_model_info": {"type": "boolean", "default": true},
                "log_diagnostics": {"type": "boolean", "default": true},
                "log_scenarios": {"type": "boolean", "default": false}
              }
            }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "output_dir": {"type": ["string", "null"], "default": null},
            "keep_scenarios": {"type": "boolean", "default": false},
            "save_scenarios": {"type": "boolean", "default": false},
            "save_model_info": {"type": "boolean", "default": true},
            "save_summary": {"type": "boolean", "default": true}
          }
        },
        "metadata": {"type": "object", "default": {}}
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "save_model_debug_artifacts": {"type": "boolean", "default": false},
        "save_distribution_summary": {"type": "boolean", "default": false},
        "save_per_window_metrics": {"type": "boolean", "default": false},
        "functional_smoke": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "finite_required": {"type": "boolean", "default": true},
            "mean_abs_error_max": {"type": ["number", "null"], "default": 0.005},
            "std_ratio_min": {"type": ["number", "null"], "default": 0.5},
            "std_ratio_max": {"type": ["number", "null"], "default": 1.5},
            "crps_max": {"type": ["number", "null"], "default": 0.05},
            "energy_score_max": {"type": ["number", "null"], "default": 0.1},
            "cross_correlation_error_max": {"type": ["number", "null"], "default": 1.0}
          }
        }
      }
    }
  }
}
