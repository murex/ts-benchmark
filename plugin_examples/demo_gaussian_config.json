{
  "version": "1.0",
  "benchmark": {
    "name": "demo_gaussian_plugin_example",
    "description": "Example config using an externally installed model plugin.",
    "dataset": {
      "provider": {
        "kind": "synthetic",
        "config": {
          "generator": "regime_switching_factor_sv",
          "params": {
            "n_assets": 3,
            "seed": 51
          }
        }
      },
      "schema": {
        "layout": "tensor",
        "frequency": "B"
      },
      "semantics": {},
      "metadata": {}
    },
    "protocol": {
      "train_size": 180,
      "test_size": 60,
      "context_length": 12,
      "horizon": 4,
      "eval_stride": 20,
      "train_stride": 1,
      "n_model_scenarios": 16,
      "n_reference_scenarios": 32
    },
    "models": [
      {
        "name": "demo_gaussian",
        "reference": {
          "kind": "plugin",
          "value": "demo_gaussian_plugin"
        },
        "params": {
          "ridge": 1e-06
        },
        "pipeline": {
          "name": "raw",
          "steps": []
        }
      },
      {
        "name": "historical_bootstrap",
        "reference": {
          "kind": "builtin",
          "value": "historical_bootstrap"
        },
        "params": {
          "block_size": 2
        },
        "pipeline": {
          "name": "raw",
          "steps": []
        }
      }
    ]
  },
  "run": {
    "seed": 51,
    "execution": {
      "scheduler": "auto"
    },
    "output": {
      "keep_scenarios": false
    }
  }
}
